{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "identifier": "com.glossary.reader",
  "productName": "Glossary",
  "app": {
    "windows": [
      {
        "title": "Glossary",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'none'; frame-src 'self' blob:; script-src 'self'" }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"]
  }
}
